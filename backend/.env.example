# Rename this file to .env before running the backend

# Secret key used to sign JWT auth tokens. Change this to a long random string in production.
SECRET_KEY=finrelief-ai-super-secret-key-change-me
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60

# SQLite database file (relative to backend/ folder)
DATABASE_URL=sqlite:///./finrelief.db

# Google Gemini API key - get one from https://aistudio.google.com/app/apikey
# If left blank, the app automatically falls back to a rule-based negotiation
# letter/strategy generator so the platform still works end-to-end without a key.
GEMINI_API_KEY=
GEMINI_MODEL=gemini-1.5-flash
